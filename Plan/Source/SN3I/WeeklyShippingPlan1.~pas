procedure TWeeklyShippingPlan.Button1Click(Sender: TObject);
begin
  with Query2 do
  begin
    Active := false;
    SQL.Clear;
    {SQL.Add('SELECT Date, Container, SUBSTRING(Container, CHARINDEX(''['', Container)+1, CHARINDEX('']'', Container) - CHARINDEX(''['', Container)-1) AS ContainerName,');
    SQL.Add('SUM(Pairs) AS Pairs, SUM(Cartons) AS Cartons, SUM(CBM) AS CBM, MIN(Seq) AS MinSeq, MAX(Seq) AS MaxSeq FROM ShippingPlan');
    SQL.Add('WHERE Date BETWEEN ''' + FormatDateTime('yyyy/MM/dd', DTP1.Date) + ''' AND ''' + FormatDateTime('yyyy/MM/dd', DTP2.Date) + ''' AND GSBH = ''' + main.Edit2.Text + '''');
    SQL.Add('GROUP BY Date, Container');
    SQL.Add('ORDER BY Date, MIN(Seq)');}

    SQL.Add('IF OBJECT_ID(''tempdb..#SP'') IS NOT NULL');
    SQL.Add('BEGIN DROP TABLE #SP END;');

    SQL.Add('IF OBJECT_ID(''tempdb..#Container'') IS NOT NULL');
    SQL.Add('BEGIN DROP TABLE #Container END;');

    SQL.Add('SELECT SP.Date, SP.Container, LBZLS.YWSM AS Country, ROW_NUMBER() OVER(PARTITION BY Date ORDER BY SP.Seq) AS Seq, SP.Pairs, SP.Cartons, SP.CBM INTO #SP FROM ShippingPlan AS SP');
    SQL.Add('LEFT JOIN DDZL ON DDZL.DDBH = SP.RY');
    SQL.Add('LEFT JOIN LBZLS ON LBZLS.LBDH = DDZL.DDGB AND LBZLS.LB = ''06''');
    SQL.Add('WHERE SP.Date BETWEEN ''' + FormatDateTime('yyyy/MM/dd', DTP1.Date) + ''' AND ''' + FormatDateTime('yyyy/MM/dd', DTP2.Date) + ''' AND SP.GSBH = ''' + main.Edit2.Text + '''');

    SQL.Add('SELECT ROW_NUMBER() OVER(ORDER BY SP1.Seq) AS ID, SP1.Date, SP1.Container, SP1.Country, SP1.Seq INTO #Container FROM #SP AS SP1');
    SQL.Add('LEFT JOIN (');
    SQL.Add('  SELECT Date, Container, Country, Seq FROM #SP');
    SQL.Add('  UNION ALL');
    SQL.Add('  SELECT SP.Date, '''' AS Container, '''' AS Country, SPMax.Seq FROM #SP AS SP');
    SQL.Add('  LEFT JOIN (');
    SQL.Add('    SELECT Date, COUNT(*) + 1 AS Seq FROM #SP');
    SQL.Add('    GROUP BY Date');
    SQL.Add('  ) AS SPMax ON SPMax.Date = SP.Date');
    SQL.Add('  WHERE SP.Seq = 1');
    SQL.Add(') AS SP2 ON SP2.Date = SP1.Date AND SP2.Seq = SP1.Seq + 1');
    SQL.Add('WHERE SP1.Container <> SP2.Container OR SP1.Country <> SP2.Country');

    SQL.Add('SELECT C.Date, C.Container, C.Country, SUBSTRING(C.Container, CHARINDEX(''['', C.Container)+1, CHARINDEX('']'', C.Container) - CHARINDEX(''['', C.Container)-1) AS ContainerName,');
    SQL.Add('SUM(SP.Pairs) AS Pairs, SUM(SP.Cartons) AS Cartons, SUM(SP.CBM) AS CBM, CAST(C.MinSeq AS INT) AS MinSeq, CAST(C.MaxSeq AS INT) AS MaxSeq FROM (');
    SQL.Add('  SELECT C1.Date, C1.Container, C1.Country, ISNULL(C2.Seq + 1, 1) AS MinSeq, C1.Seq AS MaxSeq FROM #Container AS C1');
    SQL.Add('  LEFT JOIN #Container AS C2 ON C2.Date = C1.Date AND C2.ID = C1.ID - 1');
    SQL.Add(') AS C');
    SQL.Add('LEFT JOIN #SP AS SP ON SP.Date = C.Date AND SP.Seq BETWEEN C.MinSeq AND C.MaxSeq');
    SQL.Add('GROUP BY C.Date, C.Container, C.Country, C.MinSeq, C.MaxSeq');
    SQL.Add('ORDER BY C.Date, C.MinSeq');
    Active := true;
  end;

  with Query1 do
  begin
    Active := false;
    DataSource := DS2;
    SQL.Clear;
    SQL.Add('SELECT SP.Date, SP.Container, SP.Seq, SP.Building, SP.RY, SP.PO, SP.SKU, XXZL.XieMing, SP.Pairs, SP.Cartons, SP.CBM, SP.Country, SP.Remark, SP.GSBH, SP.UserID, SP.UserDate, SP.YN FROM ShippingPlan AS SP');
    SQL.Add('LEFT JOIN DDZL ON DDZL.DDBH = SP.RY');
    SQL.Add('LEFT JOIN XXZL ON XXZL.XieXing = DDZL.XieXing AND XXZL.SheHao = DDZL.SheHao');
    SQL.Add('WHERE SP.Date = :Date AND SP.Container = :Container AND SP.Seq BETWEEN :MinSeq AND :MaxSeq AND SP.GSBH = ''' + main.Edit2.Text + '''');
    SQL.Add('ORDER BY SP.Date, SP.Seq');
    Active := true;
  end;
end;

procedure TWeeklyShippingPlan.B1D8Click(Sender: TObject);
var
  eclApp, Sheet: OleVariant;
  Building, Container, Invoice: string;
  PlanDate: TDate;
  i, Page, TCol, TRow, Col, Row, Seq, Counter, ContainerID, LastContainerSeq: integer;
begin
  SetLength(DateList, 0);
  SetLength(InvoiceList, 0);
  try
    if (OpenDialog1.Execute) then
    begin
      with Query2 do
      begin
        Active := false;
        SQL.Clear;
        SQL.Add('SELECT Date, Container, Container AS ContainerName, CAST('''' AS VARCHAR(50)) AS Country, Pairs, Cartons, CBM, 0 AS MinSeq, 0 AS MaxSeq FROM ShippingPlan');
        SQL.Add('WHERE 1 = 0');
        Active := true;
      end;

      with Query1 do
      begin
        DataSource := Nil;
        Active := false;
        SQL.Clear;
        SQL.Add('SELECT Date, Container, Seq, Building, RY, PO, SKU, CAST('''' AS VARCHAR(50)) AS XieMing, Pairs, Cartons, CBM, Country, Remark, GSBH, UserID, UserDate, YN FROM ShippingPlan');
        SQL.Add('WHERE 1 = 0');
        Active := true;

        RequestLive := true;
        CachedUpdates := true;
      end;

      try
        eclApp := CreateOleObject('Excel.Application');
        eclApp.workbooks.Open(OpenDialog1.FileName);

        PlanPage := TPlanPage.Create(Self);
        PlanPage.PageBox.Clear;
        for i := 1 to eclApp.WorkSheets.Count do
        begin
          if (eclApp.WorkSheets[i].Visible) then
            PlanPage.PageBox.Items.Add(eclApp.WorkSheets[i].Name);
        end;

        if (PlanPage.ShowModal = mrOK) then
        begin
          SetCursor(Screen.Cursors[crHourGlass]);
          DBGridEh1.Columns[0].Visible := true;
          DBGridEh1.Columns[1].Visible := true;
          DBGridEh1.Columns[0].HideDuplicates := false;
          DBGridEh1.Columns[1].HideDuplicates := false;
          for Page := 0 to Length(UploadPage) - 1 do
          begin
            Sheet := eclApp.WorkSheets[UploadPage[Page]];
            eclapp.Columns.Autofit;
            if (Length(UploadPage[Page]) <= 5) then
            begin
              try
                if (EncodeDate(YearOf(main.Today), StrToInt(Copy(UploadPage[Page], 1, 2)), StrToInt(Copy(UploadPage[Page], 4, 2))) >= main.Today) then
                  PlanDate := EncodeDate(YearOf(main.Today), StrToInt(Copy(UploadPage[Page], 1, 2)), StrToInt(Copy(UploadPage[Page], 4, 2)))
                else
                  PlanDate := EncodeDate(YearOf(main.Today)+1, StrToInt(Copy(UploadPage[Page], 1, 2)), StrToInt(Copy(UploadPage[Page], 4, 2)));
              except on F:Exception do
                begin
                  ShowMessage(UploadPage[Page] + ' is not a valid date format. Import denied');
                  Break;
                end;
              end;
            end
            else begin
              try
                PlanDate := EncodeDate(StrToInt(Copy(UploadPage[Page], 1, 4)), StrToInt(Copy(UploadPage[Page], 6, 2)), StrToInt(Copy(UploadPage[Page], 9, 2)));
              except on F:Exception do
                begin
                  ShowMessage(UploadPage[Page] + ' is not a valid date format. Import denied.');
                  Break;
                end;
              end;
            end;

            TCol := -1;
            TRow := -1;
            for Row := 1 to 50 do
            begin
              if (Sheet.Cells[Row, 1].Text = 'DESCRIPTION OF GOODS') then
              begin
                TRow := Row + 2;
                TCol := 1;
                Break;
              end;

              if (TRow > 0) then
                Break;
            end;

            if (TRow < 0) then
            begin
              ShowMessage('Unable to locate the order section. Import denied.');
              Break;
            end;

            for Row := 1 to 500 do
            begin
              Invoice := '';
              if (Copy(Sheet.Cells[Row, 1].Text, 1, 4) = 'INV#') then
              begin
                Invoice := Sheet.Cells[Row, 2].Text;
                Break;
              end;
            end;

            if (Invoice <> '') then
            begin
              SetLength(DateList, Length(DateList)+1);
              SetLength(InvoiceList, Length(InvoiceList) + 1);
              DateList[Length(InvoiceList)-1] := FormatDateTime('yyyy/MM/dd', PlanDate);
              InvoiceList[Length(InvoiceList)-1] := Invoice;
            end
            else begin
              ShowMessage('Unable to locate the invoice information. Import denied.');
              Break;
            end;

            Col := TCol;
            Row := TRow;
            Seq := 1;
            LastContainerSeq := 1;
            Counter := 0;
            ContainerID := 1;
            while (Counter < 5) do
            begin
              if (Pos('-', Sheet.Cells[Row, Col + 11].Text) > 0) then
              begin
                with QTemp do
                begin
                  Active := false;
                  SQL.Clear;
                  SQL.Add('SELECT DDZL.DDBH, XXZL.ARTICLE, XXZL.XieMing, LBZLS.YWSM AS Country FROM DDZL');
                  SQL.Add('LEFT JOIN LBZLS ON LBZLS.LBDH = DDZL.DDGB AND LBZLS.LB = ''06''');
                  SQL.Add('LEFT JOIN XXZL ON XXZL.XieXing = DDZL.XieXing AND XXZL.SheHao = DDZL.SheHao');
                  SQL.Add('WHERE DDZL.DDBH = ''' + Sheet.Cells[Row, Col + 11].Text + '''');
                  Active := true;
                end;

                with Query1 do
                begin
                  Append;
                  FieldByName('Date').Value := PlanDate;
                  FieldByName('Seq').Value := Seq;
                  FieldByName('Building').Value := 'DT';
                  FieldByName('RY').Value := QTemp.FieldByName('DDBH').AsString;
                  FieldByName('PO').Value := Sheet.Cells[Row, Col].Text;
                  FieldByName('SKU').Value := QTemp.FieldByName('ARTICLE').AsString;
                  FieldByName('XieMing').Value := QTemp.FieldByName('XieMing').AsString;
                  FieldByName('Pairs').Value := Sheet.Cells[Row, Col + 4].Value;
                  FieldByName('Cartons').Value := Sheet.Cells[Row, Col + 5].Value;
                  FieldByName('CBM').Value := Sheet.Cells[Row, Col + 7].Value;
                  FieldByName('Country').Value := QTemp.FieldByName('Country').AsString;
                  FieldByName('Remark').Value := Sheet.Cells[Row, Col + 8].Value;
                end;
                
                Inc(Seq);
              end
              else if (Sheet.Cells[Row, Col + 8].Text <> '') AND (Sheet.Cells[Row, Col + 2].Text = '') then
              begin
                Container := Sheet.Cells[Row, Col + 8].Text;

                if (LastContainerSeq <= Seq - 2) then
                begin
                  for i := LastContainerSeq to Seq - 2 do
                  begin
                    Query1.Prior;
                  end;

                  while not Query1.Eof do
                  begin
                    Query1.Edit;
                    Query1.FieldByName('Container').Value := 'Container-' + IntToStr(ContainerID) + ' [' + Container + ']';
                    Query1.Next;
                  end;
                end
                else begin
                  Query1.Edit;
                  Query1.FieldByName('Container').Value := 'Container-' + IntToStr(ContainerID) + ' [' + Container + ']';
                end;

                LastContainerSeq := Seq;
                Inc(ContainerID);
              end
              else if (Pos('GRAND TOTAL', Sheet.Cells[Row, Col + 2].Text) > 0) then
              begin
                Counter := 5;
              end
              else begin
                Inc(Counter);
              end;

              Inc(Row);
            end;
          end;

          Self.Cursor := crDefault;
          Query1.First;
          B1D5.Enabled := true;
          B1D6.Enabled := true;
          DBGridEh1.Columns[0].HideDuplicates := true;
          DBGridEh1.Columns[1].HideDuplicates := true;
          ShowMessage('Completed');
        end;

        eclApp.DisplayAlerts := false;
        eclApp.WorkBooks.Close;
        eclApp.Quit;
      except on F:Exception do
        begin
          DBGridEh1.Columns[0].HideDuplicates := true;
          eclApp.DisplayAlerts := false;
          eclApp.WorkBooks.Close;
          eclApp.Quit;
          ShowMessage(F.Message);
          Exit;
        end;
      end;
    end;
  except on F:Exception do
    begin
      DBGridEh1.Columns[0].HideDuplicates := true;
      ShowMessage(F.Message);
      Exit;
    end;
  end;
end;


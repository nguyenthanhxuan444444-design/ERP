  object Query1: TQuery
    DatabaseName = 'DB'
    SQL.Strings = (
      'SELECT'
      '    F.*,'
      '    F1.Name,'
      
        '    ISNULL(SUM(F.curr_weight_ch + F.curr_weight_ch1 + F.curr_wei' +
        'ght_sol), 0) AS tong'
      
        'FROM ch_Formulation_HK F left join Ch_Formula F1 on F.inv_id=F1.' +
        'hc1 and F.inv_id1= F1.hc2 and f.sol_id=F1.hc3'
      'WHERE F.id = '#39'123'#39
      'GROUP BY'
      
        '    F.id, F.create_time, F.maxweight_ch, F.maxweight_ch1, F.maxw' +
        'eight_sol,'
      
        '    F.curr_weight_ch, F.curr_weight_ch1, F.curr_weight_sol, F.ev' +
        'ent_time,'
      
        '    F.userID, F.inv_id, F.inv_id1, F.sol_id, F.YN, F.TyLe, F.GSB' +
        'H,'
      
        '    F.temperature, F.humidity, F.Batch_number, F.Batch_number_so' +
        'l,'
      '    F.number_of_spins, F1.Name')

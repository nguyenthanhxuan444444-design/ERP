procedure TForluma.Button4Click(Sender: TObject);
var
  i: Integer;
begin
  Query2.First;
  for i := 0 to Query2.RecordCount - 1 do
  begin
    if Query2.UpdateStatus = usInserted then
      UpdateSQL1.Apply(ukInsert);

    Query2.Next;
  end;

  Query2.Active := False;
  Query2.CachedUpdates := False;
  Query2.RequestLive := False;
  Query2.Active := True;
end;


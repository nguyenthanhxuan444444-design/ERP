procedure TChitiet.RotateBitmapDirect(ABitMap: TBitmap);
var
  oBitmap: TBitmap;
  x, y: integer;
begin
  oBitmap := TBitmap.Create;
  try
    oBitmap.Assign(ABitMap);

    // Hoán d?i kích thu?c
    ABitMap.Width := oBitmap.Height;
    ABitMap.Height := oBitmap.Width;

    // Duy?t vŕ xoay ngu?c l?i
    for x := 0 to oBitmap.Width - 1 do
    begin
      for y := 0 to oBitmap.Height - 1 do
      begin
        // CÔNG TH?C M?I: Xoay ngu?c chi?u kim d?ng h?
        ABitMap.Canvas.Pixels[y, oBitmap.Width - 1 - x] := oBitmap.Canvas.Pixels[x, y];
      end;
    end;
  finally
    oBitmap.Free;
  end;
end;

